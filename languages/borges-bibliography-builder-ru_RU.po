#: src/edit.js:606
msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Смена стиля переформатирует автоматически сгенерированные цитаты и сохраняет ручные правки."

#: src/edit.js:625
msgid "Visible Heading"
msgstr "Видимый заголовок"

#: src/edit.js:634
msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Необязательный заголовок, отображаемый над библиографией на сайте при наличии хотя бы одного источника."

#: src/edit.js:640
msgid "Output JSON-LD"
msgstr "Включить JSON-LD"

#: src/edit.js:648
msgid "Helps search engines and other tools understand the bibliography."
msgstr "Помогает поисковым системам и другим инструментам распознавать библиографию."

#: src/edit.js:654
msgid "Output COinS"
msgstr "Включить COinS"

#: src/edit.js:662
msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Позволяет Zotero и аналогичным инструментам обнаруживать цитаты на странице."

#: src/edit.js:668
msgid "Output CSL-JSON"
msgstr "Включить CSL-JSON"

#: src/edit.js:676
msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Делает данные цитирования доступными для повторного использования в научных инструментах и сервисах."

#: src/edit.js:682
msgid "Exports"
msgstr "Экспорт"

#: src/edit.js:688
msgid "Copy bibliography"
msgstr "Скопировать библиографию"

#: src/edit.js:691
msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Копирует текущую библиографию как обычный текст в текущем порядке и стиле."

#: src/edit.js:701
msgid "Download CSL-JSON"
msgstr "Скачать CSL-JSON"

#: src/edit.js:704
msgid "Downloads the current bibliography as structured citation data."
msgstr "Скачивает текущую библиографию как структурированные данные цитирования."

#: src/edit.js:714
msgid "Download BibTeX"
msgstr "Скачать BibTeX"

#: src/edit.js:717
msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Скачивает текущую библиографию как BibTeX для менеджеров ссылок и научно-исследовательских рабочих процессов."

#: src/edit.js:740
msgid "Download RIS"
msgstr "Скачать RIS"

#: src/edit.js:743
msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Скачивает текущую библиографию как RIS для менеджеров цитирования и процессов импорта/экспорта."

