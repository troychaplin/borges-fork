msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Копира тренутну библиографију као обичан текст у тренутном редоследу и стилу."

#: src/edit.js:701
msgid "Download CSL-JSON"
msgstr "Преузми CSL-JSON"

#: src/edit.js:704
msgid "Downloads the current bibliography as structured citation data."
